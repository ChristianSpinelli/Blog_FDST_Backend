datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int    @id @default(autoincrement())
  name      String
  username  String
  email     String @unique
  password  String
  role      String @default("aluno")
  createdAt DateTime @default(now())

  @@map("user")
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  body   String   @db.Text

  @@map("post")
}