{
  "compilerOptions": {
    "target": "ES2022",                          
    "module": "CommonJS",                        
    "lib": ["ES2022"],
    "rootDir": "./",                          
    "outDir": "./dist",                          
    "esModuleInterop": true,                     
    "forceConsistentCasingInFileNames": true,            
    "strict": true,                              
    "skipLibCheck": true,
    "types": ["node","jest"]                  
  },
  "include": ["src/**/*", "prisma.config.ts", "prisma/seed.ts"],
    
}